---
import Layout from '../layouts/Layout.astro';
import contacto from '../data/contacto.json';
import global from '../data/global.json';
---

<Layout title="Contacto — Pabellón M">
  <!-- Header 64 -->
  <header class="section_header64 color-scheme-3">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="header64_component">
            <div class="text-align-center">
              <div class="max-width-large align-center">
                <div class="margin-bottom margin-small">
                  <h1 class="heading-style-h1">{contacto.hero.title}</h1>
                </div>
                <p class="text-size-medium">{contacto.hero.subtitle}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="header64_color-wrapper">
      <div class="header100_color is-blue"></div>
      <div class="header100_color is-green"></div>
      <div class="header100_color is-orange"></div>
      <div class="header100_color is-purple"></div>
      <div class="header100_color is-red"></div>
      <div class="header100_color is-dark"></div>
    </div>
  </header>

  <!-- Contact 6 -->
  <section class="section_contact6 color-scheme-3">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="contact6_content">
            <!-- Info column -->
            <div class="contact6_content-left">
              <div>
                <div class="margin-bottom margin-small">
                  <h2 class="heading-style-h2">Información de contacto</h2>
                </div>
                <div class="contact6_contact-list">
                  <div class="contact6_item">
                    <div class="contact6_icon-wrapper">
                      <div class="icon-embed-xsmall">
                        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                          <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                      </div>
                    </div>
                    <div>
                      <div class="text-weight-bold">Dirección</div>
                      <a href={global.mapLink} target="_blank" rel="noopener noreferrer">{global.address}</a>
                    </div>
                  </div>
                  <div class="contact6_item">
                    <div class="contact6_icon-wrapper">
                      <div class="icon-embed-xsmall">
                        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
                        </svg>
                      </div>
                    </div>
                    <div>
                      <div class="text-weight-bold">Teléfono</div>
                      <a href={global.phoneHref}>{global.phone}</a>
                    </div>
                  </div>
                  <div class="contact6_item">
                    <div class="contact6_icon-wrapper">
                      <div class="icon-embed-xsmall">
                        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                          <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                      </div>
                    </div>
                    <div>
                      <div class="text-weight-bold">Correo electrónico</div>
                      <a href={global.emailHref}>{global.email}</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Form column -->
            <div class="contact6_form-block">
              <form class="contact6_form">
                <div class="form_field-2col">
                  <div class="form_field-wrapper">
                    <label for="nombre" class="text-size-small text-weight-bold">Nombre</label>
                    <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required class="form_input" />
                  </div>
                  <div class="form_field-wrapper">
                    <label for="email" class="text-size-small text-weight-bold">Correo electrónico</label>
                    <input type="email" id="email" name="email" placeholder="correo@ejemplo.com" required class="form_input" />
                  </div>
                </div>
                <div class="form_field-wrapper">
                  <label for="telefono" class="text-size-small text-weight-bold">Teléfono</label>
                  <input type="tel" id="telefono" name="telefono" placeholder="(81) 1234 5678" class="form_input" />
                </div>
                <div class="form_field-wrapper">
                  <label for="mensaje" class="text-size-small text-weight-bold">Mensaje</label>
                  <textarea id="mensaje" name="mensaje" rows="5" placeholder="¿En qué podemos ayudarte?" required class="form_input is-text-area"></textarea>
                </div>
                <div>
                  <button type="submit" class="button is-alternate">Enviar mensaje</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
