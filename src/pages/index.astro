---

<Layout title="Pabellón M.">
  <!-- Hero -->
  <header class="section_header100 color-scheme-3">
    <div class="header100_color-wrapper">
      <div class="header100_color is-blue"></div>
      <div class="header100_color is-green"></div>
      <div class="header100_color is-orange"></div>
      <div class="header100_color is-purple"></div>
      <div class="header100_color is-red"></div>
      <div class="header100_color is-dark"></div>
    </div>
    <div class="padding-global">
      <div class="header100_component">
        <div class="header100_card">
          <div class="header100_card-content">
            <div class="max-width-xlarge">
              <div class="text-align-center">
                <div class="margin-bottom margin-small">
                  <h1 class="heading-style-h0">{home.hero.title}</h1>
                </div>
                <div class="max-width-medium align-center">
                  <p class="text-size-medium text-wrap-balance">{home.hero.subtitle}</p>
                </div>
              </div>
            </div>
            <div class="margin-top margin-medium">
              <div class="button-group is-center">
                <a href="/nosotros" class="button is-alternate">Conócenos</a>
                <a href="/directorio" class="button is-secondary is-alternate">Directorio</a>
              </div>
            </div>
          </div>
          <div class="header100_background-video-wrapper">
            <div class="video-overlay-layer">
              <img src="/images/68efe24bc39ef6a763b37516_m_icon-cropped.svg" loading="lazy" alt="" class="icon_bg-image" />
            </div>
            <div class="header100_background-video" style={`background-image: url('/images/68ef0ffdf572c270a5ec825f_6928e13c72f9d5720511d76b_PM_hero_poster.0000000.jpg'); background-size: cover; background-position: center;`}></div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Marquee Banner -->
  <section class="section_banner-marquee color-scheme-3">
    <div class="padding-section-large">
      <div class="banner-top_component">
        <div class="banner-top_wrapper">
          <div class="banner-top_track">
            {[...marqueeTop, ...marqueeTop].map((item) => (
              <div class="marquee_item">
                <div class="marquee_image-wrapper">
                  {item.img ? (
                    <img src={`/images/${item.img}`} loading="lazy" alt={item.name} class="marquee_image" />
                  ) : (
                    <div class="marquee_image"></div>
                  )}
                </div>
                <a class="marquee-link" href={`/directorio#${item.slug}`}>
                  <span class="marquee_text">{item.name}</span>
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="banner-bottom_component">
        <div class="banner-bottom_wrapper">
          <div class="banner-bottom_track">
            {[...marqueeBottom, ...marqueeBottom].map((item) => (
              <div class="marquee_item">
                <div class="marquee_image-wrapper">
                  {item.img ? (
                    <img src={`/images/${item.img}`} loading="lazy" alt={item.name} class="marquee_image" />
                  ) : (
                    <div class="marquee_image"></div>
                  )}
                </div>
                <a class="marquee-link" href={`/directorio#${item.slug}`}>
                  <span class="marquee_text">{item.name}</span>
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Secondary Hero - "Donde la vida urbana cobra sentido" -->
  <header class="section_header62 color-scheme-1">
    <div class="padding-global z-index-1">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="header62_component">
            <div class="text-align-center">
              <div class="max-width-large align-center">
                <div class="margin-bottom margin-medium">
                  <img src="/images/68efe1ddbc9a84047c2b9718_m_icon.svg" loading="lazy" alt="" class="icon-1x1-medium" />
                </div>
                <div class="margin-bottom margin-small">
                  <h1 class="heading-style-h1">{home.secondaryHeading}</h1>
                </div>
                <div class="max-width-medium align-center">
                  <p class="text-size-medium text-color-white50">{home.secondaryIntro}</p>
                </div>
                <div class="margin-top margin-medium">
                  <div class="button-group is-center">
                    <a href="/nosotros" class="button">Conoce nuestra historia</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="icon_bg-wrapper">
      <img src="/images/68efe0641b8f6e393a588cb6_pm_icon.svg" loading="lazy" alt="" class="icon_bg-image" />
    </div>
  </header>

  <!-- Layout520 - Cards -->
  <section class="section_layout520 color-scheme-3">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="layout520_component">
            <div class="margin-bottom margin-xxlarge">
              <div class="text-align-center">
                <div class="max-width-large align-center">
                  <div class="margin-bottom margin-small">
                    <h2 class="heading-style-h2">{home.secondarySubheading}</h2>
                  </div>
                  <p class="text-size-medium">{home.secondaryDescription}</p>
                </div>
              </div>
            </div>
            <div class="layout520_grid-list">
              <div class="layout520_row">
                {home.sections.map((section, i) => (
                  <div class="layout520_card text-color-white">
                    <div class="layout520_background-image-wrapper">
                      <div class="image-overlay-layer"></div>
                      <img src={cardImages[i]} loading="lazy" alt={section.title} class="layout520_background-image" />
                    </div>
                    <div class="layout520_card-content">
                      <div class="layout520_card-content-top">
                        <div class="margin-bottom margin-xsmall">
                          <h3 class="heading-style-h4">{section.title}</h3>
                        </div>
                        <p>{section.description}</p>
                      </div>
                      <div class="margin-top margin-small">
                        <div class="button-group">
                          <a href={section.link} class="button is-secondary is-alternate">Ver más</a>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section_cta3 text-color-white">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="cta3_component">
            <div class="max-width-large">
              <div class="margin-bottom margin-small">
                <h2 class="heading-style-h2">{home.cta.heading}</h2>
              </div>
              <div class="max-width-medium">
                <p class="text-size-medium">{home.cta.description}</p>
              </div>
              <div class="margin-top margin-medium">
                <div class="button-group">
                  <a href="/contacto" class="button is-alternate">Contáctanos</a>
                  <a href="/directorio" class="button is-alternate is-secondary">Ver directorio</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="cta3_background-image-wrapper">
      <div class="image-overlay-layer"></div>
      <img src="/images/68efe3b38723b1875b5ddfa3_Pabellon_M_Interiors_Jul_25_2014.avif" loading="lazy" alt="" class="cta3_background-image" />
    </div>
  </section>
</Layout>
