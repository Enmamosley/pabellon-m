---
import global from '../data/global.json';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(base.replace(/\/$/, ''), '');
---

<div data-collapse="medium" role="banner" class="navbar1_component color-scheme-3">
  <div class="navbar1_container">
    <a href={base} class="navbar1_logo-link">
      <img loading="lazy" src={`${base}images/68ef297e785cf2199917e78c_7d8237551b97379b31ebad7751db2084_pm_logo.svg`} alt="Pabellón M" class="navbar1_logo" />
    </a>
    <nav class="navbar1_menu" id="nav-menu">
      <div class="navbar1_menu-links">
        <a href={`${base}nosotros`} class:list={["navbar1_link", { "is-active": currentPath === "/nosotros" || currentPath === "/nosotros/" }]}>Nosotros</a>
        <a href={`${base}directorio`} class:list={["navbar1_link", { "is-active": currentPath === "/directorio" || currentPath === "/directorio/" }]}>Directorio</a>
        <a href={`${base}mapa`} class:list={["navbar1_link", { "is-active": currentPath === "/mapa" || currentPath === "/mapa/" }]}>Mapa</a>
        <a href={`${base}informes`} class:list={["navbar1_link", { "is-active": currentPath === "/informes" || currentPath === "/informes/" }]}>Informes</a>
        <div class="navbar1_dropdown">
          <div class="navbar1_dropdown-toggle">
            <div>Más</div>
            <div class="dropdown-chevron">
              <svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M2.55806 6.29544C2.46043 6.19781 2.46043 6.03952 2.55806 5.94189L3.44195 5.058C3.53958 4.96037 3.69787 4.96037 3.7955 5.058L8.00001 9.26251L12.2045 5.058C12.3021 4.96037 12.4604 4.96037 12.5581 5.058L13.4419 5.94189C13.5396 6.03952 13.5396 6.19781 13.4419 6.29544L8.17678 11.5606C8.07915 11.6582 7.92086 11.6582 7.82323 11.5606L2.55806 6.29544Z" fill="currentColor"></path>
              </svg>
            </div>
          </div>
          <nav class="navbar1_dropdown-list">
            <a href="https://www.escenariognpseguros.com/" target="_blank" rel="noopener noreferrer" class="navbar1_dropdown-link">Escenario GNP</a>
            <a href="https://www.convencionespabellonm.com/" target="_blank" rel="noopener noreferrer" class="navbar1_dropdown-link">Centro de Convenciones</a>
            <a href="https://www.forocorona.com/" target="_blank" rel="noopener noreferrer" class="navbar1_dropdown-link">Foro Corona</a>
            <a href="https://www.fiestamericanatravelty.com/fiesta-americana/hoteles/fiesta-americana-monterrey-pabellon-m" target="_blank" rel="noopener noreferrer" class="navbar1_dropdown-link">Hotel Fiesta Americana</a>
          </nav>
        </div>
      </div>
      <div class="navbar1_menu-buttons">
        <a href={`${base}contacto`} class="button is-secondary is-small">Contacto</a>
      </div>
    </nav>
    <button class="menu-icon1" id="menu-toggle" aria-label="Abrir menú">
      <div class="menu-icon1_line-top"></div>
      <div class="menu-icon1_line-middle">
        <div class="menu-icon1_line-middle-inner"></div>
      </div>
      <div class="menu-icon1_line-bottom"></div>
    </button>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('nav-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('is-open');
  });
</script>
