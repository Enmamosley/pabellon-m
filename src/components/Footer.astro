---
import global from '../data/global.json';

const base = import.meta.env.BASE_URL;
---

<footer class="footer15_component color-scheme-2">
  <div class="padding-global">
    <div class="padding-section-large">
      <div class="container-large">
        <div class="footer15_top-wrapper">
          <div class="footer15_menu-wrapper">
            <a href={base} class="footer15_logo-link">
              <img src={`${base}images/68efd19e84d065f59630f65c_da1ff5f70fbd6dae5031f49900d0b798_pm_logo-white.svg`} alt="Pabellón M" class="footer15_logo" />
            </a>
            <div class="footer15_link-list">
              <a href={`${base}nosotros`} class="footer15_link">Nosotros</a>
              <a href={`${base}directorio`} class="footer15_link">Directorio</a>
              <a href={`${base}mapa`} class="footer15_link">Mapa</a>
              <a href={`${base}informes`} class="footer15_link">Informes</a>
              <a href={`${base}contacto`} class="footer15_link">Contacto</a>
            </div>
          </div>
          <div class="footer15_details-wrapper">
            <div class="footer15_social-list">
              <!-- Facebook -->
              <a href="https://www.facebook.com/PabellonMoficial" target="_blank" rel="noopener noreferrer" class="footer15_social-link">
                <div class="icon-embed-small">
                  <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22 12.0611C22 6.50451 17.5229 2 12 2C6.47715 2 2 6.50451 2 12.0611C2 17.0828 5.65684 21.2452 10.4375 22V14.9694H7.89844V12.0611H10.4375V9.84452C10.4375 7.32296 11.9305 5.93012 14.2146 5.93012C15.3088 5.93012 16.4531 6.12663 16.4531 6.12663V8.60261H15.1922C13.95 8.60261 13.5625 9.37822 13.5625 10.1739V12.0611H16.3359L15.8926 14.9694H13.5625V22C18.3432 21.2452 22 17.0828 22 12.0611Z" fill="currentColor"></path>
                  </svg>
                </div>
              </a>
              <!-- Instagram -->
              <a href="https://www.instagram.com/pabellonm/" target="_blank" rel="noopener noreferrer" class="footer15_social-link">
                <div class="icon-embed-small">
                  <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M16 3H8C5.23858 3 3 5.23858 3 8V16C3 18.7614 5.23858 21 8 21H16C18.7614 21 21 18.7614 21 16V8C21 5.23858 18.7614 3 16 3ZM19.25 16C19.2445 17.7926 17.7926 19.2445 16 19.25H8C6.20735 19.2445 4.75549 17.7926 4.75 16V8C4.75549 6.20735 6.20735 4.75549 8 4.75H16C17.7926 4.75549 19.2445 6.20735 19.25 8V16ZM16.75 8.25C17.3023 8.25 17.75 7.80228 17.75 7.25C17.75 6.69772 17.3023 6.25 16.75 6.25C16.1977 6.25 15.75 6.69772 15.75 7.25C15.75 7.80228 16.1977 8.25 16.75 8.25ZM12 7.5C9.51472 7.5 7.5 9.51472 7.5 12C7.5 14.4853 9.51472 16.5 12 16.5C14.4853 16.5 16.5 14.4853 16.5 12C16.5027 10.8057 16.0294 9.65957 15.1849 8.81508C14.3404 7.97059 13.1943 7.49734 12 7.5ZM9.25 12C9.25 13.5188 10.4812 14.75 12 14.75C13.5188 14.75 14.75 13.5188 14.75 12C14.75 10.4812 13.5188 9.25 12 9.25C10.4812 9.25 9.25 10.4812 9.25 12Z" fill="currentColor"></path>
                  </svg>
                </div>
              </a>
              <!-- X/Twitter -->
              <a href="https://x.com/PabellonM" target="_blank" rel="noopener noreferrer" class="footer15_social-link">
                <div class="icon-embed-small">
                  <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17.1761 4H19.9362L13.9061 10.7774L21 20H15.4456L11.0951 14.4066L6.11723 20H3.35544L9.80517 12.7508L3 4H8.69545L12.6279 9.11262L17.1761 4ZM16.2073 18.3754H17.7368L7.86441 5.53928H6.2232L16.2073 18.3754Z" fill="currentColor"></path>
                  </svg>
                </div>
              </a>
              <!-- LinkedIn -->
              <a href="https://www.linkedin.com/company/pabellonm/" target="_blank" rel="noopener noreferrer" class="footer15_social-link">
                <div class="icon-embed-small">
                  <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M5 3H19C20.1046 3 21 3.89543 21 5V19C21 20.1046 20.1046 21 19 21H5C3.89543 21 3 20.1046 3 19V5C3 3.89543 3.89543 3 5 3ZM8 18C8.27614 18 8.5 17.7761 8.5 17.5V10.5C8.5 10.2239 8.27614 10 8 10H6.5C6.22386 10 6 10.2239 6 10.5V17.5C6 17.7761 6.22386 18 6.5 18H8ZM7.25 9C6.42157 9 5.75 8.32843 5.75 7.5C5.75 6.67157 6.42157 6 7.25 6C8.07843 6 8.75 6.67157 8.75 7.5C8.75 8.32843 8.07843 9 7.25 9ZM17.5 18C17.7761 18 18 17.7761 18 17.5V12.9C18.0325 11.3108 16.8576 9.95452 15.28 9.76C14.177 9.65925 13.1083 10.1744 12.5 11.1V10.5C12.5 10.2239 12.2761 10 12 10H10.5C10.2239 10 10 10.2239 10 10.5V17.5C10 17.7761 10.2239 18 10.5 18H12C12.2761 18 12.5 17.7761 12.5 17.5V13.75C12.5 12.9216 13.1716 12.25 14 12.25C14.8284 12.25 15.5 12.9216 15.5 13.75V17.5C15.5 17.7761 15.7239 18 16 18H17.5Z" fill="currentColor"></path>
                  </svg>
                </div>
              </a>
              <!-- YouTube -->
              <a href="https://www.youtube.com/@PabellonM" target="_blank" rel="noopener noreferrer" class="footer15_social-link">
                <div class="icon-embed-small">
                  <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M20.9968 6.00209C21.5095 6.51476 21.8291 7.18543 21.9018 7.90209C22.1468 10.6121 22.1468 13.3921 21.9018 16.1021C21.8291 16.8188 21.5095 17.4894 20.9968 18.0021C20.4841 18.5148 19.8135 18.8344 19.0968 18.9071C16.3868 19.1521 13.6068 19.1521 10.8968 18.9071C10.1801 18.8344 9.50948 18.5148 8.99681 18.0021C8.48414 17.4894 8.16449 16.8188 8.09181 16.1021C7.84681 13.3921 7.84681 10.6121 8.09181 7.90209C8.16449 7.18543 8.48414 6.51476 8.99681 6.00209C9.50948 5.48943 10.1801 5.16977 10.8968 5.09709C13.6068 4.85209 16.3868 4.85209 19.0968 5.09709C19.8135 5.16977 20.4841 5.48943 20.9968 6.00209ZM14.0018 15.0021L18.0018 12.0021L14.0018 9.00209V15.0021Z" fill="currentColor"></path>
                  </svg>
                </div>
              </a>
            </div>
            <p class="text-size-small">{global.address}</p>
            <a href={global.phoneHref} class="footer15_link">{global.phone}</a>
            <a href={global.emailHref} class="footer15_link">{global.email}</a>
          </div>
        </div>
        <div class="spacer-large"></div>
        <div class="divider-horizontal"></div>
        <div class="spacer-medium"></div>
        <div class="footer15_bottom-wrapper">
          <div class="footer15_legal-list">
            <div class="footer15_credit-text">{global.copyright}</div>
            <a href={`${base}legal/aviso-de-privacidad`} class="footer15_legal-link">Aviso de privacidad</a>
          </div>
          <div class="text-icon-wrapper">
            <div class="footer15_credit-text">Un desarrollo de</div>
            <img src={`${base}images/6928e31f2c9987142bdda8f4_IDN_Logo.png`} alt="IDN" loading="lazy" class="footer15_credit-logo" />
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
